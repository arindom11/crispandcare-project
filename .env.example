# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Backend port (Vite proxies /api to this). On Render this is set automatically.
PORT=3001

# Database — LEAVE BLANK for local development (the app uses a local SQLite file).
# In production (Render), set this to your Neon Postgres connection string and the
# app switches to Postgres automatically so orders persist across redeploys.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin page password — used to view incoming orders at /admin
ADMIN_PASSWORD=change-me-please

# Your UPI ID for the "Pay by UPI QR" option (e.g. yourname@okhdfcbank)
UPI_ID=example@upi
UPI_PAYEE_NAME=Crisp & Care

# Razorpay keys — get them free at https://dashboard.razorpay.com (Settings -> API Keys).
# Start with TEST mode keys (they begin with rzp_test_). Swap to live keys when you go live.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
